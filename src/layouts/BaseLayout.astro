---

export interface Props {
    title?: string;
}
const { title = "权芯365 - 个人技术作品集" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    
    
    <title>{title}</title>
    
    
    
    
    
    <link rel="canonical" href="https://www.quanxin365.cn" />
    

    <script type="application/ld+json">
        {
            "@context": "https://schema.org"
            "@graph": [
                {
                    "@type": "WebSite",
                    "名称": "权芯365"
