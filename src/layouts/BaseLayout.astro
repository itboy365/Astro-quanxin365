    </script>

    <style is:global>
        /* ===== 以下是你原网站的所有 CSS，完整保留 ===== */
        :root {
            --bg: #FAF7F2;
            --surface: rgba(255, 252, 247, 0.75);
            --surface-hover: rgba(255, 252, 247, 0.92);
            --text: #2C2C2C;
            --text-secondary: #6B6B6B;
            --text-muted: #9B9B9B;
            --vermilion: #C43D3D;
            --vermilion-soft: rgba(196, 61, 61, 0.08);
            --gold: #C49B4C;
            --gold-soft: rgba(196, 155, 76, 0.08);
            --ink-blue: #1C2838;
            --ink-blue-soft: rgba(28, 40, 56, 0.08);
            --jade: #2D8B6E;
            --jade-soft: rgba(45, 139, 110, 0.08);
            --glass-border: rgba(180, 170, 155, 0.2);
            --glass-border-hover: rgba(180, 170, 155, 0.35);
            --glass-shadow: 0 4px 32px rgba(60, 40, 20, 0.06);
            --glass-shadow-hover: 0 16px 48px rgba(60, 40, 20, 0.11);
            --glass-highlight: rgba(255, 255, 255, 0.5);
            --radius-sm: 12px;
            --radius: 22px;
            --radius-lg: 28px;
            --gap: 1.5rem;
            --section-gap: 2.5rem;
            --section-gap-sm: 1.2rem;
            --max-width: 1000px;
            --font: 'Inter', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', system-ui, -apple-system, sans-serif;
            --font-mono: 'JetBrains Mono', 'SF Mono', 'Cascadia Code', 'Consolas', monospace;
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #141C26;
                --surface: rgba(24, 32, 46, 0.7);
                --surface-hover: rgba(28, 38, 54, 0.85);
                --text: #E8E4DD;
                --text-secondary: #A8A49B;
                --text-muted: #6E6B64;
                --glass-border: rgba(120, 110, 95, 0.25);
                --glass-border-hover: rgba(160, 145, 120, 0.4);
                --glass-shadow: 0 4px 32px rgba(0, 0, 0, 0.3);
                --glass-shadow-hover: 0 16px 48px rgba(0, 0, 0, 0.45);
                --glass-highlight: rgba(255, 255, 255, 0.04);
                --vermilion-soft: rgba(196, 61, 61, 0.18);
                --gold-soft: rgba(196, 155, 76, 0.15);
                --ink-blue-soft: rgba(100, 140, 180, 0.15);
                --jade-soft: rgba(45, 139, 110, 0.15);
            }
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 1.25rem;
            line-height: 1.7;
            background-image: radial-gradient(ellipse at 8% 15%, rgba(196, 61, 61, 0.04) 0%, transparent 50%), radial-gradient(ellipse at 88% 80%, rgba(196, 155, 76, 0.04) 0%, transparent 50%), radial-gradient(ellipse at 50% 50%, rgba(45, 139, 110, 0.02) 0%, transparent 60%);
            transition: background 0.5s var(--ease-out-expo), color 0.5s var(--ease-out-expo);
        }
        .container { max-width: var(--max-width); width: 100%; display: flex; flex-direction: column; gap: var(--section-gap); }
        .brand-section { text-align: center; animation: fadeUpIn 0.7s var(--ease-out-expo) both; }
        .brand-section .logo {
            font-size: clamp(2.6rem, 5vw, 3.6rem);
            font-weight: 850;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, #C43D3D 0%, #8B2D2D 35%, #C49B4C 70%, #C43D3D 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            color: transparent;
            animation: gradientShift 6s ease-in-out infinite;
            display: inline-block;
        }
        .brand-section .subtitle { display: block; margin-top: 0.6rem; font-size: 1.05rem; font-weight: 500; color: var(--text-secondary); letter-spacing: 0.04em; animation: fadeUpIn 0.7s var(--ease-out-expo) 0.1s both; }
        @keyframes gradientShift { 0%,100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
        @keyframes fadeUpIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }

        .intro-section { text-align: left; max-width: 560px; margin: 0 auto; margin-top: calc(var(--section-gap-sm) - var(--section-gap)); animation: fadeUpIn 0.7s var(--ease-out-expo) 0.2s both; }
        .intro-section p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.85; letter-spacing: 0.02em; text-indent: 2em; margin-bottom: 0.6rem; }
        .intro-section p:last-child { margin-bottom: 0; }

        .works-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: var(--gap); animation: fadeUpIn 0.7s var(--ease-out-expo) 0.3s both; }

        .card {
            background: var(--surface);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius);
            padding: 2rem 1.8rem;
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            transition: all 0.45s var(--ease-out-expo);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            cursor: default;
        }
        .card::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--glass-highlight); opacity: 0; transition: opacity 0.45s var(--ease-out-expo); pointer-events: none; z-index: 0; border-radius: var(--radius); }
        .card:hover { transform: translateY(-6px); box-shadow: var(--glass-shadow-hover); border-color: var(--glass-border-hover); background: var(--surface-hover); }
        .card:hover::after { opacity: 1; }
        .card > * { position: relative; z-index: 1; }
        .card-icon { font-size: 2rem; margin-bottom: 0.7rem; display: inline-block; width: fit-content; transition: transform 0.45s var(--ease-spring); }
        .card:hover .card-icon { transform: scale(1.1); }
        .card h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.35rem; letter-spacing: -0.01em; }
        .card .card-desc { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; flex: 1; margin-bottom: 1.2rem; }
        .card .card-link {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-weight: 650;
            text-decoration: none;
            font-size: 0.9rem;
            padding: 0.55rem 1.1rem;
            border-radius: var(--radius-sm);
            transition: all 0.35s var(--ease-out-expo);
            align-self: flex-start;
            letter-spacing: 0.02em;
            position: relative;
        }
        .card .card-link::after { content: ''; position: absolute; inset: 0; border-radius: var(--radius-sm); opacity: 0; transition: opacity 0.35s var(--ease-out-expo); pointer-events: none; z-index: -1; }

        .card-news { border-left: 4px solid rgba(196, 61, 61, 0.5); }
        .card-news .card-icon { filter: drop-shadow(0 0 12px rgba(196, 61, 61, 0.3)); }
        .card-news .card-link { color: #B03A3A; background: var(--vermilion-soft); }
        .card-news .card-link::after { background: rgba(196, 61, 61, 0.18); }
        .card-news .card-link:hover::after { opacity: 1; }
        .card-news:hover { border-left-color: rgba(196, 61, 61, 0.75); }

        .card-gold { border-left: 4px solid rgba(196, 155, 76, 0.5); }
        .card-gold .card-icon { filter: drop-shadow(0 0 12px rgba(196, 155, 76, 0.35)); }
        .card-gold .card-link { color: #8B6914; background: var(--gold-soft); }
        .card-gold .card-link::after { background: rgba(196, 155, 76, 0.18); }
        .card-gold .card-link:hover::after { opacity: 1; }
        .card-gold:hover { border-left-color: rgba(196, 155, 76, 0.75); }

        .card-blog { border-left: 4px solid rgba(28, 40, 56, 0.45); }
        .card-blog .card-icon { filter: drop-shadow(0 0 12px rgba(28, 40, 56, 0.25)); }
        .card-blog .card-link { color: #1C2838; background: var(--ink-blue-soft); }
        .card-blog .card-link::after { background: rgba(28, 40, 56, 0.15); }
        .card-blog .card-link:hover::after { opacity: 1; }
        .card-blog:hover { border-left-color: rgba(28, 40, 56, 0.7); }

        .card-service { border-left: 4px solid rgba(45, 139, 110, 0.45); }
        .card-service .card-icon { filter: drop-shadow(0 0 10px rgba(45, 139, 110, 0.25)); }
        .card-service .card-link { color: #1F6B52; background: var(--jade-soft); }
        .card-service .card-link::after { background: rgba(45, 139, 110, 0.18); }
        .card-service .card-link:hover::after { opacity: 1; }
        .card-service:hover { border-left-color: rgba(45, 139, 110, 0.7); }

        .footer {
            text-align: center;
            animation: fadeUpIn 0.7s var(--ease-out-expo) 0.4s both;
            padding-top: 0.25rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
        }
        .footer .copyright { font-size: 0.85rem; font-weight: 700; color: var(--text); letter-spacing: 0.03em; }
        .footer .email-line { display: flex; align-items: center; justify-content: center; gap: 0.35rem; font-size: 0.85rem; }
        .footer .email-icon { font-size: 0.95rem; opacity: 0.8; transition: opacity 0.2s; }
        .footer .email-link { color: var(--gold); text-decoration: none; font-weight: 500; transition: all 0.2s; cursor: pointer; border-bottom: 1px solid transparent; }
        .footer .email-link:hover { color: var(--vermilion); border-bottom-color: var(--vermilion); }
        .footer .timer-line { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.04em; display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0.3rem; }
        .footer .timer-display {
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 0.95rem;
            background: linear-gradient(90deg, #E84848, #F0A030, #E8D44D, #48C060, #4098E0, #7848D8, #D84898, #E84848);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            color: transparent;
            animation: rainbowFlow 3s linear infinite;
            display: inline-block;
        }
        @keyframes rainbowFlow { 0% { background-position: 0% 50%; } 100% { background-position: 300% 50%; } }

        .email-toast-overlay { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 9999; background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); animation: overlayIn 0.25s var(--ease-out-expo); }
        .email-toast-overlay.closing { animation: overlayOut 0.25s var(--ease-out-expo) forwards; }
        .email-toast { background: rgba(30, 35, 45, 0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.12); border-radius: var(--radius); padding: 2rem 2.2rem; text-align: center; box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4); animation: toastIn 0.35s var(--ease-spring); max-width: 380px; width: 90%; color: #E8E4DD; }
        .email-toast.closing { animation: toastOut 0.2s var(--ease-out-expo) forwards; }
        .email-toast .toast-icon { font-size: 1.8rem; margin-bottom: 0.6rem; }
        .email-toast .toast-title { font-weight: 700; font-size: 1rem; margin-bottom: 0.4rem; }
        .email-toast .toast-email { font-family: var(--font-mono); font-size: 0.9rem; color: #F0C060; background: rgba(255, 255, 255, 0.06); padding: 0.35rem 0.8rem; border-radius: 6px; display: inline-block; margin-bottom: 0.8rem; letter-spacing: 0.02em; }
        .email-toast .toast-question { font-size: 0.9rem; color: #C0BBB2; margin-bottom: 1.2rem; }
        .email-toast .toast-buttons { display: flex; gap: 0.8rem; justify-content: center; }
        .email-toast .btn-cancel, .email-toast .btn-confirm { padding: 0.55rem 1.6rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; cursor: pointer; border: none; transition: all 0.2s; font-family: var(--font); }
        .email-toast .btn-cancel { background: rgba(255, 255, 255, 0.1); color: #C0BBB2; }
        .email-toast .btn-cancel:hover { background: rgba(255, 255, 255, 0.18); color: #E8E4DD; }
        .email-toast .btn-confirm { background: #C43D3D; color: #fff; }
        .email-toast .btn-confirm:hover { background: #D94A4A; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(196, 61, 61, 0.35); }
        @keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes overlayOut { from { opacity: 1; } to { opacity: 0; } }
        @keyframes toastIn { from { opacity: 0; transform: translateY(20px) scale(0.94); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes toastOut { from { opacity: 1; transform: scale(1); } to { opacity: 0; transform: scale(0.92); } }

        @media (max-width: 768px) {
            body { padding: 1.8rem 1rem; }
            .works-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
            .card { padding: 1.6rem 1.4rem; }
            .brand-section .logo { font-size: 2.2rem; }
            .brand-section .subtitle { font-size: 0.9rem; }
            .intro-section { text-align: left; }
        }
        @media (max-width: 480px) {
            body { padding: 1.2rem 0.75rem; }
            .card { padding: 1.4rem 1.1rem; border-radius: var(--radius-sm); }
            .brand-section .logo { font-size: 1.9rem; }
            .email-toast { padding: 1.5rem 1.4rem; }
            .email-toast .toast-buttons { flex-direction: column; gap: 0.5rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <slot />   <!-- 页面内容会插入这里 -->
    </div>

    <!-- 全局邮箱弹窗 -->
    <div class="email-toast-overlay" id="emailOverlay" style="display:none;" aria-hidden="true">
        <div class="email-toast" id="emailToast" role="dialog" aria-modal="true" aria-labelledby="toastTitle">
            <div class="toast-icon">📋</div>
            <div class="toast-title" id="toastTitle">您已成功复制邮箱</div>
            <div class="toast-email">itboy@quanxin365.cn</div>
            <div class="toast-question">是否发送邮件？</div>
            <div class="toast-buttons">
                <button class="btn-cancel" id="btnCancel">取消</button>
                <button class="btn-confirm" id="btnConfirm">确定</button>
            </div>
        </div>
    </div>

    <!-- 全局页脚（每个页面底部都有） -->
    <footer class="footer">
        <p class="copyright">© 权芯365</p>
        <div class="email-line">
            <span class="email-icon" aria-hidden="true">✉</span>
            <a class="email-link" id="emailTrigger" href="javascript:void(0)" title="点击复制邮箱">itboy@quanxin365.cn</a>
        </div>
        <div class="timer-line">
            <span>本站已安全运行：</span>
            <span class="timer-display" id="timer">0000 天 00 时 00 分 00 秒</span>
        </div>
    </footer>

    <!-- 全局交互脚本 -->
    <script>
        (function() {
            const timerEl = document.getElementById('timer');
            const startDate = new Date('2023-07-30T00:00:00+08:00');
            function pad(n) { return String(n).padStart(2, '0'); }
            function updateTimer() {
                const now = new Date();
                const diff = now - startDate;
                const totalSeconds = Math.floor(diff / 1000);
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;
                timerEl.textContent = String(days).padStart(4, '0') + ' 天 ' + pad(hours) + ' 时 ' + pad(minutes) + ' 分 ' + pad(seconds) + ' 秒';
            }
            updateTimer();
            setInterval(updateTimer, 1000);
            const now = new Date();
            if (now.getMonth() === 6 && now.getDate() === 1) {
                timerEl.style.background = '#C43D3D';
                timerEl.style.webkitBackgroundClip = 'text';
                timerEl.style.backgroundClip = 'text';
                timerEl.style.webkitTextFillColor = 'transparent';
                timerEl.style.color = 'transparent';
                timerEl.style.animation = 'none';
                timerEl.title = '7月1日 · 中国心的日子';
            }
            const emailTrigger = document.getElementById('emailTrigger');
            const overlay = document.getElementById('emailOverlay');
            const toast = document.getElementById('emailToast');
            const btnCancel = document.getElementById('btnCancel');
            const btnConfirm = document.getElementById('btnConfirm');
            const emailAddr = 'itboy@quanxin365.cn';
            let autoCloseTimer = null;
            function openToast() {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(emailAddr).catch(() => {});
                } else {
                    const ta = document.createElement('textarea');
                    ta.value = emailAddr;
                    ta.style.position = 'fixed';
                    ta.style.left = '-9999px';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                }
                overlay.style.display = 'flex';
                overlay.classList.remove('closing');
                toast.classList.remove('closing');
                overlay.setAttribute('aria-hidden', 'false');
                autoCloseTimer = setTimeout(closeToast, 5000);
            }
            function closeToast() {
                if (autoCloseTimer) {
                    clearTimeout(autoCloseTimer);
                    autoCloseTimer = null;
                }
                overlay.classList.add('closing');
                toast.classList.add('closing');
                setTimeout(function() {
                    overlay.style.display = 'none';
                    overlay.classList.remove('closing');
                    toast.classList.remove('closing');
                    overlay.setAttribute('aria-hidden', 'true');
                }, 250);
            }
            function sendEmail() {
                closeToast();
                window.location.href = 'mailto:' + emailAddr;
            }
            emailTrigger.addEventListener('click', function(e) {
                e.preventDefault();
                openToast();
            });
            btnCancel.addEventListener('click', function(e) {
                e.stopPropagation();
                closeToast();
            });
            btnConfirm.addEventListener('click', function(e) {
                e.stopPropagation();
                sendEmail();
            });
            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) {
                    closeToast();
                }
            });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && overlay.style.display === 'flex') {
                    closeToast();
                }
            });
        })();
    </script>
</body>
</html>