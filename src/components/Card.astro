---
export interface Props {
    icon: string;
    title: string;
    description: string;
    link: string;
    linkText: string;
    cardClass: string;
}
const { icon, title, description, link, linkText, cardClass } = Astro.props;
---

<article class={`card ${cardClass}`}>
    <span class="card-icon" aria-hidden="true">{icon}</span>
    <h2>{title}</h2>
    <p class="card-desc">{description}</p>
    <a href={link} class="card-link" target="_blank" rel="noopener noreferrer">{linkText} →</a>
</article>